{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": [
    "risk_mode",
    "dry_run"
  ],
  "properties": {
    "risk_mode": {
      "type": "string",
      "enum": [
        "safe",
        "balanced",
        "aggressive"
      ]
    },
    "dry_run": {
      "type": "boolean"
    }
  }
}