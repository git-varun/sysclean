#!/usr/bin/env bash

set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
export PYTHONPATH="$ROOT_DIR/python"

echo "Starting syscleand daemon..."

# Handle signal for graceful shutdown
trap 'echo "syscleand stopping..."; exit 0' SIGINT SIGTERM

exec python3 "$ROOT_DIR/python/core/worker.py"
