#!/usr/bin/env bash

set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
export PYTHONPATH="$ROOT_DIR/python"

source "$ROOT_DIR/lib/logger.sh"
source "$ROOT_DIR/lib/ui.sh"
source "$ROOT_DIR/lib/config.sh"
source "$ROOT_DIR/lib/guards.sh"
source "$ROOT_DIR/lib/dependencies.sh"
source "$ROOT_DIR/lib/confirm.sh"
# telemetry and execution might not be needed in CLI if daemon handles it
# but we'll source them just in case
source "$ROOT_DIR/lib/telemetry.sh"
source "$ROOT_DIR/lib/execution.sh"

shopt -s nullglob
for mod in "$ROOT_DIR/modules/"*.sh; do
  source "$mod"
done
shopt -u nullglob

CONFIG_PATH="/etc/sysclean/default.yml"

COMMAND="${1:-help}"
shift || true

PYTHON="python3"
if [ -x "$ROOT_DIR/venv/bin/python" ]; then
    PYTHON="$ROOT_DIR/venv/bin/python"
elif [ -x "$ROOT_DIR/.venv/bin/python" ]; then
    PYTHON="$ROOT_DIR/.venv/bin/python"
fi

init_logger

if [ -f "$ROOT_DIR/.env" ]; then
    set -a
    source "$ROOT_DIR/.env"
    set +a
fi

load_config "$CONFIG_PATH"
validate_environment

case "$COMMAND" in
  clean)
    info "Starting cleanup workflow"
    # CLI just enqueues, or sends operation to daemon
    run_pipeline "apt"
    run_pipeline "docker"
    run_pipeline "snap"
    run_pipeline "cache"
    ;;
  queue)
    show_queue
    ;;
  rollback)
    info "Executing rollback subsystem"
    "$PYTHON" "$ROOT_DIR/python/core/engine.py" "$@"
    ;;
  ui)
    info "Starting Web UI server on port 8080..."
    # Set CWD to root so uvicorn can find python.web.server
    cd "$ROOT_DIR"
    "$PYTHON" -m uvicorn python.web.server:app --port 8080 &
    SERVER_PID=$!
    sleep 2
    if command -v xdg-open >/dev/null; then
        xdg-open "http://localhost:8080"
    elif command -v open >/dev/null; then
        open "http://localhost:8080"
    else
        "$PYTHON" -m webbrowser "http://localhost:8080"
    fi
    info "Web UI running. Press Ctrl+C to stop."
    wait $SERVER_PID
    ;;
  client)
    info "Sending operation to daemon"
    "$PYTHON" "$ROOT_DIR/python/core/client.py" "$@"
    ;;
  advise)
    info "Requesting AI Advisory"
    "$PYTHON" "$ROOT_DIR/python/ai/advisory.py" "${1:-}"
    ;;
  help|*)
    cat <<EOF
SysClean CLI

Commands:
  clean       Execute cleanup workflow
  queue       Inspect execution queue
  rollback    Rollback metadata
  ui          Open Web UI dashboard
  client      Send manual operation to daemon
  advise      Request AI recommendations (docker|apt|storage)
EOF
    ;;
esac
