#!/usr/bin/env bash

set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"

source "$ROOT_DIR/lib/logger.sh"
source "$ROOT_DIR/lib/ui.sh"
source "$ROOT_DIR/lib/config.sh"
source "$ROOT_DIR/lib/guards.sh"
source "$ROOT_DIR/lib/dependencies.sh"
source "$ROOT_DIR/lib/confirm.sh"
source "$ROOT_DIR/lib/queue.sh"
source "$ROOT_DIR/lib/telemetry.sh"
source "$ROOT_DIR/lib/execution.sh"

for mod in "$ROOT_DIR/modules/"*.sh; do
  source "$mod"
done

CONFIG_PATH="${HOME}/.config/sysclean/config/default.yml"


COMMAND="${1:-help}"
shift || true

init_logger
load_config "$CONFIG_PATH"
validate_environment
initialize_telemetry

case "$COMMAND" in

  heal)
    python3 python/healing/runtime.py
    ;;

  incidents)
    python3 python/incidents/response.py
    ;;

  consensus)
    python3 python/consensus/runtime.py
    ;;

  copilot)
    python3 python/copilots/runtime.py
    ;;

  memory)
    python3 python/memory_graph/runtime.py
    ;;

  adaptive)
    python3 python/adaptive/runtime.py
    ;;

  cognition)
    python3 python/cognition/runtime.py
    ;;

  simulate)
    python3 python/simulation/runtime.py
    ;;

  rl)
    python3 python/reinforcement/agent.py
    ;;

  prevent)
    python3 python/prevention/runtime.py
    ;;

  evolve)
    python3 python/evolution/governance.py
    ;;

  awareness)
    python3 python/awareness/runtime.py
    ;;

  fleet)
    python3 python/fleet/agent.py
    ;;

  graph)
    python3 python/graph/resource_graph.py
    ;;

  cve)
    python3 python/security/cve.py
    ;;

  remediate)
    python3 python/remediation/engine.py
    ;;

  forecast)
    python3 python/forecasting/ml_forecast.py
    ;;

  mesh)
    python3 python/mesh/runtime.py
    ;;

  drift)
    python3 python/drift/detector.py
    ;;

  twin)
    python3 python/twin/runtime.py
    ;;

  predict)
    python3 python/prediction/maintenance.py
    ;;

  semantic)
    python3 python/semantic/intelligence.py
    ;;

  vectors)
    python3 python/vectors/memory.py
    ;;

  daemon)
    info "Starting syscleand daemon"
    python3 "$ROOT_DIR/python/executor/worker.py"
    ;;

  client)
    info "Sending operation to daemon"
    python3 "$ROOT_DIR/python/executor/client.py" "$2"
    ;;

  clean)
    info "Starting cleanup workflow"
    run_pipeline "apt"
    run_pipeline "docker"
    run_pipeline "snap"
    run_pipeline "cache"
    ;;

  tui)
    python3 python/tui/dashboard.py
    ;;

  web)
    uvicorn python.web.server:app --reload
    ;;

  analyze)
    python3 python/intelligence/health.py
    ;;

  ai)
    python3 python/ai/providers/ollama.py
    ;;

  doctor)
    dependency_doctor
    ;;

  report)
    info "Generating reports"
    ;;

  queue)
    show_queue
    ;;

  rollback)
    info "Executing rollback subsystem"
    python3 -c "
import sys
import os
sys.path.insert(0, os.path.join('$ROOT_DIR', 'python'))
from rollback.engine import execute_rollback
execute_rollback()
"
    ;;

  help|*)
    cat <<EOF
SysClean CLI

Commands:
  clean       Execute cleanup workflow
  analyze     Analyze system bloat
  doctor      Dependency and environment checks
  report      Generate reports
  queue       Inspect execution queue
  rollback    Rollback metadata
EOF
    ;;
esac